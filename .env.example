# Скопируй в .env (без .example) и впиши свои ключи — .env в .gitignore,
# в репозиторий не попадёт. Нужны только для локальных одноразовых
# скриптов генерации (scripts/*), само приложение в рантайме их не читает.

ELEVENLABS_API_KEY=
# Необязательно — id голоса из твоего кабинета ElevenLabs.
# Если не задать, используется дефолтный многоязычный голос.
ELEVENLABS_VOICE_ID=

OPENAI_API_KEY=
# Необязательно — один из голосов OpenAI TTS (alloy, verse, ...).
OPENAI_TTS_VOICE=
